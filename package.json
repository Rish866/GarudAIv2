{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "echo \"No linter configured yet\"",
    "test": "vitest run tests/unit/ tests/integration/",
    "test:watch": "vitest",
    "test:rls": "vitest run tests/rls/",
    "test:integration": "vitest run tests/integration/",
    "test:e2e": "playwright test",
    "test:e2e:auth": "playwright test tests/e2e/auth.spec.ts",
    "test:e2e:workflow1": "playwright test tests/e2e/workflow1.spec.ts",
    "test:e2e:trips": "playwright test tests/e2e/trip-operations.spec.ts",
    "test:e2e:headed": "playwright test --headed",
    "typecheck": "tsc --noEmit",
    "security:generate": "node scripts/generate-authorization-manifest.mjs",
    "security:validate": "node scripts/validate-authorization-manifest.mjs",
    "security:check": "npm run security:generate && npm run security:validate",
    "migration:generate": "node scripts/generate-migration-004.mjs && node scripts/generate-migration-005.mjs",
    "migration:check": "node scripts/generate-migration-004.mjs --check && node scripts/generate-migration-005.mjs --check"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/leaflet": "^1.9.21",
    "@vitejs/plugin-react": "^5.0.4",
    "date-fns": "^4.4.0",
    "express": "^4.21.2",
    "framer-motion": "^12.42.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.9.2",
    "vite": "^6.2.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  }
}
