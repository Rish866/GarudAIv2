# ============================================================
# GARUD AI TRANSPORT ERP — Environment Variables
# ============================================================
# Copy this file to .env for local development.
# In production, set these via your hosting platform's dashboard.
# NEVER commit .env to version control.
# ============================================================

# ─── REQUIRED: Supabase Configuration ─────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── OPTIONAL: Platform Admin ─────────────────────────────────
# Email of the super-admin who can see all organizations.
# This is a UI-only flag; real admin access is enforced by database RLS.
VITE_PLATFORM_ADMIN_EMAIL=

# ─── SERVER: Production Settings ──────────────────────────────
# Set NODE_ENV=production for production deployments
NODE_ENV=development

# Port for the Express server (default: 3000)
PORT=3000

# Comma-separated list of allowed CORS origins (production only)
# If not set, same-origin requests only are allowed in production.
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ─── SESSION: Timeout Configuration ──────────────────────────
# Idle session timeout in minutes (default: 30)
VITE_SESSION_TIMEOUT_MINUTES=30

# ─── E2E TESTING (DO NOT SET IN PRODUCTION) ──────────────────
# E2E_BASE_URL=http://localhost:3000
# E2E_TEST_EMAIL=
# E2E_TEST_PASSWORD=
# E2E_OWNER_EMAIL=
# E2E_OWNER_PASSWORD=
# E2E_VIEWER_EMAIL=
# E2E_VIEWER_PASSWORD=
# E2E_MIGRATION_007=true
